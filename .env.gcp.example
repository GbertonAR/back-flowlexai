# =======================================================
# FlowLexAI — Variables de Entorno para Google Cloud Run
# AUTOR:  Gustavo Berton | FlowState AI | 2026-05-12
# =======================================================
# INSTRUCCIONES:
#   1. Copiar este archivo y renombrarlo a .env.gcp (NO commitear con valores reales)
#   2. Reemplazar todos los placeholders REPLACE_*
#   3. Los valores marcados con [Secret Manager] deben cargarse via --update-secrets
#      en el deploy de Cloud Run (ver cloudbuild.yaml)
# =======================================================

# ── Proyecto GCP ──────────────────────────────────────
GCP_PROJECT_ID=REPLACE_CON_TU_PROJECT_ID
GCP_REGION=us-central1

# ── Base de Datos (Cloud SQL PostgreSQL) ──────────────
# El servidor usa socket Unix cuando POSTGRES_SERVER empieza con /cloudsql/
POSTGRES_SERVER=/cloudsql/REPLACE_PROJECT_ID:us-central1:flowlexai-db
POSTGRES_USER=flowlexai
POSTGRES_PASSWORD=REPLACE_CON_SECRET_MANAGER          # [Secret Manager: lexia-db-password]
POSTGRES_DB=flowlex
POSTGRES_PORT=5432

# ── Encryption / JWT ──────────────────────────────────
ENCRYPTION_KEY=REPLACE_CON_SECRET_MANAGER             # [Secret Manager: lexia-encryption-key]
SECRET_KEY=REPLACE_CON_SECRET_MANAGER                 # [Secret Manager: lexia-secret-key]
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Azure OpenAI (mantener hasta migrar a Vertex AI) ──
OPENAI_API_KEY=REPLACE_CON_SECRET_MANAGER             # [Secret Manager: lexia-openai-key]
OPENAI_ENDPOINT=https://ai-flowlex.openai.azure.com/
OPENAI_API_VERSION=2024-05-01-preview
CHAT_DEPLOYMENT=flowlex-chat
EMBEDDING_DEPLOYMENT=flowlex-embedding

# ── Email (notificaciones demo) ───────────────────────
EMAIL_USERNAME=gbertonnft@gmail.com
EMAIL_PASSWORD=REPLACE_CON_SECRET_MANAGER             # [Secret Manager: lexia-email-password]
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_NOTIFICATIONS_TO=gberton1967@gmail.com

# ── CORS ──────────────────────────────────────────────
# Reemplazar con las URLs reales de Cloud Run tras el primer deploy
ALLOWED_ORIGINS=https://flowlexai-frontend-HASH-uc.a.run.app,https://flowlexai.com

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=medio
APP_ENV=production
